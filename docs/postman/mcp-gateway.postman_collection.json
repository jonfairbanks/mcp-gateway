{
  "info": {
    "_postman_id": "a21564bb-4a7f-4fd4-b127-a8db3c02b415",
    "name": "MCP Gateway",
    "description": "Postman collection for the MCP Gateway HTTP API. Set the collection variables `base_url` and `admin_token` first. Requests under Self Service and MCP Transport use `user_token`, which can be populated automatically by the Admin Create User request when `issue_api_key` is true. MCP transport requests target `POST /mcp` and send `MCP-Protocol-Version: {{protocol_version}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{admin_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "admin_token",
      "value": "change-me-admin"
    },
    {
      "key": "user_token",
      "value": "change-me-user"
    },
    {
      "key": "protocol_version",
      "value": "2025-11-25"
    },
    {
      "key": "subject",
      "value": "alice"
    },
    {
      "key": "user_id",
      "value": ""
    },
    {
      "key": "group_id",
      "value": ""
    },
    {
      "key": "key_id",
      "value": ""
    },
    {
      "key": "upstream_id",
      "value": "github"
    },
    {
      "key": "permission",
      "value": "admin.usage.read"
    },
    {
      "key": "tool_name",
      "value": ""
    },
    {
      "key": "session_id",
      "value": "",
      "disabled": true
    }
  ],
  "item": [
    {
      "name": "Public & Observability",
      "item": [
        {
          "name": "GET /healthz",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/healthz",
            "description": "Liveness check."
          }
        },
        {
          "name": "GET /readyz",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/readyz",
            "description": "Readiness check. Returns 503 until at least one upstream is usable."
          }
        },
        {
          "name": "GET /tools",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/tools",
            "description": "HTTP tools catalog. This may require auth unless `gateway.public_tools_catalog` is enabled."
          }
        },
        {
          "name": "GET /metrics",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/metrics",
            "description": "Prometheus/OpenMetrics scrape endpoint."
          }
        }
      ]
    },
    {
      "name": "MCP Transport",
      "item": [
        {
          "name": "POST /mcp initialize",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{user_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "MCP-Protocol-Version",
                "value": "{{protocol_version}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"initialize-1\",\n  \"method\": \"initialize\",\n  \"params\": {\n    \"protocolVersion\": \"{{protocol_version}}\",\n    \"capabilities\": {},\n    \"clientInfo\": {\n      \"name\": \"postman\",\n      \"version\": \"1.0\"\n    }\n  }\n}"
            },
            "url": "{{base_url}}/mcp",
            "description": "Initialize the MCP session and negotiate the current protocol version."
          }
        },
        {
          "name": "GET /mcp",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{user_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "MCP-Protocol-Version",
                "value": "{{protocol_version}}"
              }
            ],
            "url": "{{base_url}}/mcp",
            "description": "Method probe. The gateway does not offer GET SSE streams on `/mcp` and returns HTTP 405 with `Allow: POST`."
          }
        },
        {
          "name": "DELETE /mcp",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{user_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [
              {
                "key": "MCP-Protocol-Version",
                "value": "{{protocol_version}}"
              }
            ],
            "url": "{{base_url}}/mcp",
            "description": "Method probe. The gateway does not support session deletion on `/mcp` and returns HTTP 405 with `Allow: POST`."
          }
        },
        {
          "name": "POST /mcp tools/list",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{user_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "MCP-Protocol-Version",
                "value": "{{protocol_version}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"tools-list-1\",\n  \"method\": \"tools/list\",\n  \"params\": {}\n}"
            },
            "url": "{{base_url}}/mcp",
            "description": "Merged MCP tool discovery over the current protocol version."
          }
        },
        {
          "name": "POST /mcp tools/call",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{user_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "MCP-Protocol-Version",
                "value": "{{protocol_version}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": \"tool-call-1\",\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"{{tool_name}}\",\n    \"arguments\": {}\n  }\n}"
            },
            "url": "{{base_url}}/mcp",
            "description": "Tool execution. Set `tool_name` to a real tool from `tools/list`."
          }
        },
        {
          "name": "POST /mcp batch",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{user_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "MCP-Protocol-Version",
                "value": "{{protocol_version}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"jsonrpc\": \"2.0\",\n    \"id\": \"batch-1\",\n    \"method\": \"tools/list\",\n    \"params\": {}\n  },\n  {\n    \"jsonrpc\": \"2.0\",\n    \"method\": \"notifications/initialized\",\n    \"params\": {}\n  }\n]"
            },
            "url": "{{base_url}}/mcp",
            "description": "JSON-RPC batch request on `POST /mcp`. Notification-only inputs return HTTP 202 with no body."
          }
        }
      ]
    },
    {
      "name": "Self Service",
      "item": [
        {
          "name": "GET /v1/me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{user_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/v1/me",
            "description": "Current principal profile."
          }
        },
        {
          "name": "GET /v1/me/api-keys",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{user_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/v1/me/api-keys"
          }
        },
        {
          "name": "POST /v1/me/api-keys",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code !== 201) {",
                  "  return;",
                  "}",
                  "const data = pm.response.json();",
                  "if (data.id) {",
                  "  pm.collectionVariables.set('key_id', data.id);",
                  "}",
                  "if (data.api_key) {",
                  "  pm.collectionVariables.set('user_token', data.api_key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{user_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"postman\",\n  \"expires_at\": null\n}"
            },
            "url": "{{base_url}}/v1/me/api-keys"
          }
        },
        {
          "name": "DELETE /v1/me/api-keys/{key_id}",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{user_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/v1/me/api-keys/{{key_id}}",
            "description": "Set `key_id` from a previous list/create response."
          }
        }
      ]
    },
    {
      "name": "Admin - Users & Identities",
      "item": [
        {
          "name": "GET /v1/admin/users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/v1/admin/users"
          }
        },
        {
          "name": "POST /v1/admin/users",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code !== 201) {",
                  "  return;",
                  "}",
                  "const data = pm.response.json();",
                  "if (data.user && data.user.id) {",
                  "  pm.collectionVariables.set('user_id', data.user.id);",
                  "}",
                  "if (data.user && data.user.subject) {",
                  "  pm.collectionVariables.set('subject', data.user.subject);",
                  "}",
                  "if (data.issued_api_key && data.issued_api_key.id) {",
                  "  pm.collectionVariables.set('key_id', data.issued_api_key.id);",
                  "}",
                  "if (data.issued_api_key && data.issued_api_key.api_key) {",
                  "  pm.collectionVariables.set('user_token', data.issued_api_key.api_key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"{{subject}}\",\n  \"display_name\": \"Alice\",\n  \"issue_api_key\": true,\n  \"key_label\": \"default\"\n}"
            },
            "url": "{{base_url}}/v1/admin/users",
            "description": "Creates a managed user. With `issue_api_key: true`, the returned plaintext API key is stored into `user_token`."
          }
        },
        {
          "name": "PATCH /v1/admin/users/{user_id}",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"display_name\": \"Alice Updated\",\n  \"role\": null,\n  \"is_active\": true\n}"
            },
            "url": "{{base_url}}/v1/admin/users/{{user_id}}",
            "description": "Set `user_id` from the create/list response."
          }
        },
        {
          "name": "GET /v1/admin/identities",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/v1/admin/identities"
          }
        },
        {
          "name": "PUT /v1/admin/identities/{subject}",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"display_name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"is_active\": true\n}"
            },
            "url": "{{base_url}}/v1/admin/identities/{{subject}}"
          }
        },
        {
          "name": "PATCH /v1/admin/identities/{subject}",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"display_name\": \"Alice Patched\",\n  \"email\": \"alice+patched@example.com\",\n  \"is_active\": true\n}"
            },
            "url": "{{base_url}}/v1/admin/identities/{{subject}}"
          }
        },
        {
          "name": "GET /v1/admin/integrations",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/v1/admin/integrations",
            "description": "Use the returned `id` values as `upstream_id` when creating integration grants."
          }
        },
        {
          "name": "GET /v1/admin/usage",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/admin/usage?group_by=subject",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "admin",
                "usage"
              ],
              "query": [
                {
                  "key": "group_by",
                  "value": "subject"
                },
                {
                  "key": "from",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "to",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Valid `group_by` values are `subject`, `integration`, and `api_key`. `user` is accepted as an alias for `subject`."
          }
        }
      ]
    },
