flowchart TB
    C["Client<br/>Codex / Claude / other MCP client"]
    H["HTTP Gateway<br/>/mcp, auth, rate limit, parse request"]
    G["Gateway Core<br/>route request, apply policy, check cache"]

    U["Upstream MCPs<br/>Context7, Notion, Endor, AWS"]
    P["Postgres<br/>logs + persistent cache"]
    M["Metrics Registry<br/>served at /metrics"]

    C -->|"POST /mcp"| H
    H --> G
    G -->|"cache miss / discovery"| U
    U -->|"result"| G
    G -->|"write logs + cache"| P
    G -->|"update counters"| M
    G -->|"response"| H
    H -. "JSON-RPC response" .-> C

    classDef client fill:#e8f3ff,stroke:#4a90e2,color:#111;
    classDef gateway fill:#fdecec,stroke:#d9534f,color:#111,stroke-width:2px;
    classDef upstream fill:#eef8ee,stroke:#5cb85c,color:#111;
    classDef store fill:#f7f7f7,stroke:#666,color:#111;

    class C client;
    class H,G gateway;
    class U upstream;
    class P,M store;
